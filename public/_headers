# Content-hashed build assets (index-<hash>.js, sample-<hash>.wav, etc.)
# never change for a given hash — cache them hard and never revalidate.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The entry document must always be revalidated so it points at the latest
# asset hashes after a deploy. Never let a browser run a stale index.html.
/index.html
  Cache-Control: no-cache
/
  Cache-Control: no-cache

# Social preview image is stable but small — a shorter cache is fine so a
# refreshed OG card propagates within an hour.
/og-image.png
  Cache-Control: public, max-age=3600
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
